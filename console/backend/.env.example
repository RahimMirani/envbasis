DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SECRETS_MASTER_KEY=<your-fernet-key>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
CLI_AUTH_JWT_SECRET=<any-long-random-secret>
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Base URL of the dashboard (used in project invite emails as ?invite=<token>)
INVITE_APP_BASE_URL=http://localhost:5173
# Optional: send invite emails via SMTP. If unset, invites are stored and the link is logged server-side.
# INVITE_SMTP_HOST=
# INVITE_SMTP_PORT=587
# INVITE_SMTP_USER=
# INVITE_SMTP_PASSWORD=
# INVITE_FROM_EMAIL=
# INVITE_SMTP_USE_TLS=true
